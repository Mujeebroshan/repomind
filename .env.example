# ── Local LLM backend ──────────────────────────────────────────────────
LOCAL_BACKEND=ollama              # ollama | lmstudio
OLLAMA_HOST=http://localhost:11434
LMSTUDIO_HOST=http://localhost:1234/v1
LOCAL_CHAT_MODEL=qwen2.5-coder:7b
LOCAL_EMBED_MODEL=nomic-embed-text

# ── Frontier / cloud providers (optional) ──────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_ESCALATION_PROVIDER=gemini

# ── Understanding pipeline ─────────────────────────────────────────────
ANALYSIS_DEPTH=standard           # quick | standard | deep
MAX_CONCURRENT_SUMMARIES=4        # parallel Ollama summary requests
USE_CLOUD_FOR_PROJECT_SUMMARY=true
